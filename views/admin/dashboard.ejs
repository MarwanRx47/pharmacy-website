<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/header') %>
<div class="glass-container admin-container">
  <h1>🔐 Admin Dashboard</h1>
  <div style="display: flex; gap: 1rem; margin: 1rem 0; flex-wrap: wrap;">
    <a href="/admin/add-product" class="btn" style="width: auto;">➕ Add Product</a>
    <a href="/admin/orders" class="btn" style="width: auto; background: #3b82f6;">📦 View Orders</a>
    <a href="/admin/brands" class="btn" style="width: auto; background: #8b5cf6;">🏷️ Brands</a>
    <a href="/admin/ingredients" class="btn" style="width: auto; background: #06b6d4;">🔬 Ingredients</a>
    <a href="/auth/logout" class="btn" style="width: auto; background: #ef4444;">🚪 Logout</a>
  </div>
  <h2>Products List</h2>
  <h3>Filter Products</h3>
  <form id="adminFilterForm" style="display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 1rem;">
    <input type="text" id="filterName" placeholder="Product name" style="flex:1; padding:0.5rem; border-radius:0.5rem; border:1px solid #ccc;">
    <select id="filterCategory" style="padding:0.5rem; border-radius:0.5rem; border:1px solid #ccc;">
      <option value="">All Categories</option>
      <option value="cosmetic">Cosmetic</option>
      <option value="supplement">Supplement</option>
    </select>
    <select id="filterBrand" style="padding:0.5rem; border-radius:0.5rem; border:1px solid #ccc;">
      <option value="">All Brands</option>
      <% brands.forEach(b => { %>
        <option value="<%= b._id %>"><%= b.name %></option>
      <% }) %>
    </select>
    <button type="button" id="applyAdminFilter" class="btn" style="width:auto;">Filter</button>
  </form>
  <table id="productsTable" class="admin-table">
    <thead>
      <tr><th>Name</th><th>Brand</th><th>Price</th><th>Stock</th><th>Category</th><th>Actions</th></tr>
    </thead>
    <tbody>
      <% products.forEach(p => { %>
        <tr>
          <td><%= p.name %></td>
          <td><%= p.brand.name %></td>
          <td><%= p.price %> IQD</td>
          <td><%= p.stock %></td>
          <td><%= p.category %></td>
          <td><a href="/admin/edit-product/<%= p._id %>" style="color:#2563eb;">Edit</a></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>
  <%- include('../partials/footer') %>
<script>
  document.getElementById('applyAdminFilter').addEventListener('click', async () => {
    const name = document.getElementById('filterName').value;
    const category = document.getElementById('filterCategory').value;
    const brand = document.getElementById('filterBrand').value;
    let url = '/admin/products/filter?';
    if (name) url += `name=${encodeURIComponent(name)}&`;
    if (category) url += `category=${category}&`;
    if (brand) url += `brand=${brand}&`;
    const res = await fetch(url);
    const products = await res.json();
    // Re-render table tbody
    const tbody = document.querySelector('#productsTable tbody');
    tbody.innerHTML = products.map(p => `
      <tr>
        <td>${p.name}</td>
        <td>${p.brand.name}</td>
        <td>${p.price} IQD</td>
        <td>${p.stock}</td>
        <td>${p.category}</td>
        <td><a href="/admin/edit-product/${p._id}" style="color:#2563eb;">Edit</a></td>
      </tr>
    `).join('');
  });
</script>
</body>
</html>