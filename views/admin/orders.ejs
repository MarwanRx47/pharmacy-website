<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Orders | Admin</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/header') %>
<div class="glass-container admin-container">
  <h1>📦 Orders</h1>
  <div style="margin-bottom: 1rem;">
    <a href="/admin" class="btn" style="width: auto; display: inline-block;">← Back to Dashboard</a>
  </div>
  <table class="admin-table">
    <tr><th>User</th><th>Products</th><th>Pickup Time</th><th>Status</th><th>Action</th></tr>
    <% orders.forEach(order => { %>
      <tr>
        <td><%= order.user ? order.user.email : 'Unknown' %></td>
        <td>
          <% order.products.forEach(p => { %>
            <%= p.product.name %> (x<%= p.quantity %>)<br>
          <% }) %>
        </td>
        <td><%= order.pickupTime.toLocaleString() %></td>
        <td><%= order.status %></td>
        <td>
          <form method="POST" action="/admin/orders/update" style="display: inline;">
            <input type="hidden" name="orderId" value="<%= order._id %>">
            <select name="status" style="padding: 0.3rem; border-radius: 0.5rem; border: 1px solid #ccc;">
              <option value="pending">Pending</option>
              <option value="ready">Ready for pickup</option>
              <option value="completed">Completed</option>
            </select>
            <button type="submit" style="padding: 0.3rem 0.6rem; font-size: 0.8rem;">Update</button>
          </form>
        </td>
      </tr>
    <% }) %>
  </table>
</div>
</body>
</html>
