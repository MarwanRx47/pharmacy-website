<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>4Bax Pharmacy | <%= t('subtitle') %></title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body dir="<%= dir %>">
  <%- include('partials/header') %>
  <div class="glass-container">
    <h1>
      <span style="background: linear-gradient(135deg, #dc2626, #10b981); -webkit-background-clip: text; background-clip: text; color: transparent; font-weight: 800;">
        <% if (lang === 'en') { %>4Bax Pharmacy<% } else { %><%= t('pharmacy_name') %><% } %>
      </span>
      <span style="font-size: 1rem; color: #475569; display: block; margin-top: 0.5rem;">✨ <%= t('subtitle') %></span>
    </h1>

    <div class="layout">
      <!-- Filters sidebar -->
      <aside class="filters-panel">
        <div class="filter-toggle" style="cursor: pointer; display: flex; justify-content: space-between; align-items: center;">
          <h3 style="margin: 0;">🔍 Filters</h3>
          <span class="toggle-icon">▼</span>
        </div>
        <div class="filter-content" style="margin-top: 1rem;">
          <div class="filter-group" id="brandsContainer">
            <h3>🏷️ <%= t('brands') %></h3>
            <!-- dynamically loaded -->
          </div>
          <div class="filter-group" id="ingredientsContainer">
            <h3>🔬 <%= t('ingredients') %></h3>
            <!-- dynamically loaded -->
          </div>
        </div>
      </aside>

      <!-- Products area -->
      <main class="products-area">
        <div style="display: flex; gap: 1rem; align-items: center; margin-bottom: 1rem; flex-wrap: wrap;">
          <input type="text" id="searchInput" placeholder="🔍 <%= t('search_placeholder') %>" style="flex: 1; min-width: 200px; padding: 0.8rem; border-radius: 2rem; border: none; background: rgba(255,255,255,0.7); font-size: 1rem;">
          <select id="sortBy" style="padding: 0.8rem; border-radius: 2rem; border: none; background: rgba(255,255,255,0.7); font-size: 0.95rem;">
            <option value="name_asc">📝 Name (A-Z)</option>
            <option value="name_desc">📝 Name (Z-A)</option>
            <option value="price_asc">💰 Price (Low to High)</option>
            <option value="price_desc">💰 Price (High to Low)</option>
            <option value="brand_asc">🏷️ Brand (A-Z)</option>
          </select>
        </div>
        <div id="productList"></div>
        <div id="pagination"></div>
      </main>
    </div>
  </div>

  <div style="text-align: center; margin-top: 2rem;">
    <a href="/cart" style="background: #1e293b; color: white; padding: 0.6rem 1.5rem; border-radius: 2rem; text-decoration: none;">🛍️ <%= t('view_cart') %></a>
  </div>

  <script src="/js/main.js"></script>
  <script>
    // Collapsible filters
    const toggle = document.querySelector('.filter-toggle');
    const content = document.querySelector('.filter-content');
    const icon = document.querySelector('.toggle-icon');
    if (toggle && content) {
      toggle.addEventListener('click', () => {
        const isHidden = content.style.display === 'none';
        content.style.display = isHidden ? 'block' : 'none';
        icon.textContent = isHidden ? '▼' : '▲';
      });
    }
  </script>
  <%- include('partials/footer') %>
</body>
</html>