<div class="product-grid">
  <% products.forEach(p => { %>
    <div class="product-card">
      <img src="<%= p.imageUrl || '/images/placeholder.jpg' %>" alt="<%= p.name %>">
      <h3><%= p.name %></h3>
      <p>Brand: <%= p.brand?.name || 'Unknown' %></p>
      <p>Price: $<%= p.price %></p>
      <p>Ingredients: <%= p.ingredients?.map(i => i.name).join(', ') || 'None' %></p>
      <button type="button" onclick="addToCart('<%= p._id %>')">Add to Cart</button>
    </div>
  <% }) %>
</div>
